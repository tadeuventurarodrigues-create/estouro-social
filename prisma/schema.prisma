generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(CUSTOMER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orders       Order[]
}

model SiteConfig {
  id               Int      @id
  brandName        String   @default("Ventura Market")
  siteTitle        String   @default("Ventura Market")
  siteDescription  String   @default("Marketplace futurista de serviços digitais.")
  heroBadge        String   @default("Tema claro/escuro • API externa • Pix e cartão")
  heroTitle        String   @default("Seu site futurista para vender serviços digitais com checkout e automação.")
  heroDescription  String   @default("Projeto starter com visual roxo/preto, botões azuis, painel admin, painel cliente, catálogo, checkout e integração pronta para provedor externo e Mercado Pago.")
  logoUrl          String?
  primaryColor     String   @default("#7c3aed")
  secondaryColor   String   @default("#0f172a")
  accentColor      String   @default("#2563eb")
  backgroundColor  String   @default("#030712")
  cardColor        String   @default("#111827")
  textColor        String   @default("#f9fafb")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ProviderConfig {
  id                     Int      @id
  externalApiUrl         String?
  externalApiKey         String?
  mercadopagoAccessToken String?
  mercadopagoPublicKey   String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Service {
  id                Int      @id @default(autoincrement())
  name              String
  category          String
  description       String
  imageUrl          String?
  externalServiceId Int?
  rate              Float
  min               Int
  max               Int
  enabled           Boolean  @default(true)
  fieldsJson        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  orders            Order[]
}

model Order {
  id               Int      @id @default(autoincrement())
  customerName     String
  customerEmail    String?
  username         String?
  link             String?
  quantity         Int?
  extraJson        String?
  totalAmount      Float
  status           String   @default("pending_payment")
  externalOrderId  String?
  providerResponse String?
  paymentMethod    String?
  serviceId        Int
  userId           Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  service          Service  @relation(fields: [serviceId], references: [id])
  user             User?    @relation(fields: [userId], references: [id])
  payments         Payment[]
}

model Payment {
  id                 Int      @id @default(autoincrement())
  orderId            Int
  provider           String   @default("mercadopago")
  providerPaymentId  String?
  status             String   @default("pending")
  amount             Float
  qrCode             String?
  qrCodeBase64       String?
  checkoutUrl        String?
  rawResponse        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  order              Order    @relation(fields: [orderId], references: [id])
}